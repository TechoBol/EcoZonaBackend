// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// 🏢 UBICACIONES
//////////////////////

model Location {
  id        Int          @id @default(autoincrement())
  name      String
  type      LocationType
  address   String?
  isVisible Boolean      @default(true)

  abbreviation String?
  saleCounter  Int?    @default(0)

  employees   Employee[]
  inventories Inventory[]
  sales       Sale[]

  fromMovements StockMovement[] @relation("FromLocation")
  toMovements   StockMovement[] @relation("ToLocation")

  fromTransfers Transfer[] @relation("FromTransfer")
  toTransfers   Transfer[] @relation("ToTransfer")

  importations        Importation[]
  PublicInventoryLink PublicInventoryLink[]
  InventoryCross      InventoryCross[]
}

enum LocationType {
  WAREHOUSE
  BRANCH
}

//////////////////////
// 👤 EMPLEADOS
//////////////////////

model Employee {
  id       Int     @id @default(autoincrement())
  name     String
  lastName String
  email    String? @unique
  password String?

  role   Role @relation(fields: [roleId], references: [id])
  roleId Int

  location   Location? @relation(fields: [locationId], references: [id])
  locationId Int?

  sales Sale[]

  isVisible Boolean @default(true)

  requestedTransfers Transfer[] @relation("RequestedBy")
  approvedTransfers  Transfer[] @relation("ApprovedBy")

  createdImportations  Importation[]         @relation("ImportationCreatedBy")
  resolvedImportations Importation[]         @relation("ImportationResolvedBy")
  PublicInventoryLink  PublicInventoryLink[]
  InventoryCross       InventoryCross[]
}

model Role {
  id                  Int        @id @default(autoincrement())
  name                String
  description         String?
  employee            Employee[]
  isVisible           Boolean    @default(true)
  maxEmployeesAllowed Int        @default(1)
  level               Int?
}

//////////////////////
// 🏷️ CATEGORIZACIÓN
//////////////////////

model Line {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  brands      Json    @default("[]")
  isVisible   Boolean @default(true)

  products Product[]
}

//////////////////////
// 📦 PRODUCTOS
//////////////////////

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  barcode     String? @unique
  productCode String? @unique
  imageUrl    String?
  price       Float
  finalPrice  Float
  isVisible   Boolean @default(true)

  line   Line? @relation(fields: [lineId], references: [id])
  lineId Int?

  brandName String?

  inventories      Inventory[]
  movements        StockMovement[]
  saleDetails      SaleDetail[]
  transferItems    TransferItem[]
  importationItems ImportationItem[]
  crossesFrom      InventoryCross[]  @relation("CrossOriginProduct")
  crossesTo        InventoryCross[]  @relation("CrossDestinationProduct")

  porcentajeGanancia Float @default(0)
  quantityDiscount   Float @default(0)
  bossDiscount       Float @default(0)
}

//////////////////////
// 📊 INVENTARIO
//////////////////////

model Inventory {
  id Int @id @default(autoincrement())

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  quantity Int @default(0)

  averageCost Float @default(0)

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
}

enum ImportationType {
  MANUAL
  EXCEL
}

enum ImportationStatus {
  DRAFT
  APPROVED
  CANCELLED
}

model Importation {
  id   Int    @id @default(autoincrement())
  code String

  type ImportationType @default(EXCEL)

  fileName String?
  fileUrl  String?

  status ImportationStatus @default(DRAFT)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  // Quien creó la importación
  employee   Employee @relation("ImportationCreatedBy", fields: [employeeId], references: [id])
  employeeId Int

  // Quien aprobó o canceló
  resolvedBy   Employee? @relation("ImportationResolvedBy", fields: [resolvedById], references: [id])
  resolvedById Int?
  resolvedAt   DateTime?

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  items     ImportationItem[]
  movements StockMovement[]

  @@unique([code, locationId])
  @@index([createdAt])
  @@index([locationId])
  @@index([employeeId])
  @@index([type])
}

model ImportationItem {
  id Int @id @default(autoincrement())

  importation   Importation @relation(fields: [importationId], references: [id])
  importationId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  quantity Int

  unitCost Float

  @@index([importationId])
  @@index([productId])
}

//////////////////////
// 🔄 MOVIMIENTOS
//////////////////////

model StockMovement {
  id Int @id @default(autoincrement())

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  fromLocation   Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  fromLocationId Int?

  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  toLocationId Int?

  quantity Int

  type MovementType

  unitCost Float @default(0)

  // 🔥 OPCIONAL
  reference     String?
  transfer      Transfer?    @relation(fields: [transferId], references: [id])
  transferId    Int?
  importation   Importation? @relation(fields: [importationId], references: [id])
  importationId Int?
  createdAt     DateTime     @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([type])
  @@index([importationId])
}

enum MovementType {
  IN
  OUT
  TRANSFER
}

//////////////////////
// 🔥 TRANSFERENCIAS
//////////////////////

model Transfer {
  id           Int     @id @default(autoincrement())
  transferCode String?

  fromLocation   Location? @relation("FromTransfer", fields: [fromLocationId], references: [id])
  fromLocationId Int?

  toLocation   Location? @relation("ToTransfer", fields: [toLocationId], references: [id])
  toLocationId Int?

  status TransferStatus @default(PENDING)

  createdAt     DateTime  @default(now())
  editedAt      DateTime?
  requestedById Int
  requestedBy   Employee  @relation("RequestedBy", fields: [requestedById], references: [id])

  approvedById Int?
  approvedBy   Employee? @relation("ApprovedBy", fields: [approvedById], references: [id])

  approvedAt DateTime?
  executedAt DateTime?

  rejectionReason String?

  items     TransferItem[]
  movements StockMovement[]

  glosa String?

  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([createdAt])
}

model TransferItem {
  id Int @id @default(autoincrement())

  transfer   Transfer @relation(fields: [transferId], references: [id])
  transferId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  quantity Int

  @@index([transferId])
  @@index([productId])
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

//////////////////////
// 💰 VENTAS
//////////////////////

enum SaleStatus {
  ACTIVE
  CANCELLED
}

model Sale {
  id   Int      @id @default(autoincrement())
  date DateTime @default(now())

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  subtotal Float @default(0)

  discount Float @default(0)

  total Float

  code   String?
  pdfUrl String?

  details SaleDetail[]

  typeSale             String?
  transactionNumber    String?
  paymentMethodChanged Boolean?   @default(false)
  dateChanged          Boolean?   @default(false)
  type                 String?
  status               SaleStatus @default(ACTIVE)
  cancelReason         String?
  cancelledAt          DateTime?
  cancelledById        Int?

  customerName     String?
  customerPhone    String?
  customerDocument String?
  customerAddress  String?
  customerNote     String?

  @@index([date])
  @@index([locationId])
  @@index([employeeId])
  @@index([status])
}

model SaleDetail {
  id Int @id @default(autoincrement())

  sale   Sale @relation(fields: [saleId], references: [id])
  saleId Int

  product   Product @relation(fields: [productId], references: [id])
  productId Int

  quantity Int

  price Float

  @@index([saleId])
  @@index([productId])
}

model InventoryCross {
  id        Int      @id @default(autoincrement())
  code      String?
  createdAt DateTime @default(now())

  quantity Int

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  originProduct   Product @relation("CrossOriginProduct", fields: [originProductId], references: [id])
  originProductId Int

  destinationProduct   Product @relation("CrossDestinationProduct", fields: [destinationProductId], references: [id])
  destinationProductId Int

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  observation String?

  @@index([createdAt])
  @@index([locationId])
  @@index([employeeId])
}

model PublicInventoryLink {
  id Int @id @default(autoincrement())

  token String @unique

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int

  location   Location @relation(fields: [locationId], references: [id])
  locationId Int

  active Boolean @default(true)

  createdAt DateTime @default(now())

  views Int @default(0)
}
